{
  "name": "@opperai/cli",
  "version": "0.1.2",
  "description": "The official Opper CLI — authenticate, route agent inference, and manage the Opper platform",
  "type": "module",
  "bin": {
    "opper": "dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@opperai/login": "^0.4.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "update-notifier": "^7.3.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/update-notifier": "^6.0.8",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opper-ai/cli"
  },
  "license": "MIT",
  "keywords": [
    "opper",
    "cli",
    "ai",
    "llm"
  ]
}
